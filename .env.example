# ============================================================
#  CreateWitty — Environment variables
#  1) Copy this file to ".env"      ->   cp .env.example .env
#  2) Fill in the values from your Supabase project
#     (Supabase Dashboard -> Project Settings -> API)
#  These are PUBLIC keys (safe for the browser). Never put the
#  Supabase "service_role" secret key here.
# ============================================================

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# The email address that contact / enrollment forms are sent to (FormSubmit)
VITE_FORM_EMAIL=pranith.gorityala49@gmail.com

# Your live site URL (used for canonical URLs & sitemap). No trailing slash.
VITE_SITE_URL=https://www.createwitty.com
